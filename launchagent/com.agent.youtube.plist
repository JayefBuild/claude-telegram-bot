<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agent.youtube</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/jfrech/.bun/bin/bun</string>
        <string>run</string>
        <string>/Users/jfrech/jayef_bots/src/index.ts</string>
    </array>

    <key>WorkingDirectory</key>
